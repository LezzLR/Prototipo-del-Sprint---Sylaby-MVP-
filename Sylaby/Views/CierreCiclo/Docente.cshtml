@model IEnumerable<Sylaby.Models.Curso>
@{
    ViewData["Title"] = "Mis Cursos - Cierre de Ciclo";
}

<div class="dashboard-container">
    <!-- Academic Header -->
    <div class="dashboard-hero">
        <span class="dashboard-tag">Docente</span>
        <h1 class="dashboard-title">Encuestas de Cierre de Ciclo</h1>
        <p class="dashboard-subtitle">
            Gestione y registre el nivel de cumplimiento académico real de cada uno de sus cursos asignados al finalizar el ciclo.
        </p>
    </div>

    <!-- Alert Notifications -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="background-color: #ECFDF5; color: #065F46; border-left: 4px solid #10B981 !important; border-radius: 8px;">
            <div class="d-flex align-items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                </svg>
                <span>@TempData["SuccessMessage"]</span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="background-color: #FEF2F2; color: #991B1B; border-left: 4px solid #EF4444 !important; border-radius: 8px;">
            <div class="d-flex align-items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-exclamation-octagon-fill" viewBox="0 0 16 16">
                    <path d="M11.46.146A.5.5 0 0 0 11.107 0H4.893a.5.5 0 0 0-.353.146L.146 4.54A.5.5 0 0 0 0 4.893v6.214a.5.5 0 0 0 .146.353l4.394 4.394a.5.5 0 0 0 .353.146h6.214a.5.5 0 0 0 .353-.146l4.394-4.394a.5.5 0 0 0 .146-.353V4.893a.5.5 0 0 0-.146-.353L11.46.146zM8 4c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995A.905.905 0 0 1 8 4zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
                <span>@TempData["ErrorMessage"]</span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Courses Grid -->
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="text-center py-5 info-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-journal-x text-muted mb-3" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M6.146 6.146a.5.5 0 0 1 .708 0L8 7.293l1.146-1.147a.5.5 0 1 1 .708.708L8.707 8l1.147 1.146a.5.5 0 0 1-.708.708L8 8.707 6.854 9.854a.5.5 0 0 1-.708-.708L7.293 8 6.146 6.854a.5.5 0 0 1 0-.708z"/>
                        <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2zm0 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3z"/>
                    </svg>
                    <h3 class="h5 fw-bold text-secondary">No tienes cursos asignados</h3>
                    <p class="text-muted">Por favor, contacta con el Director o Administración para tu asignación académica.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var curso in Model)
            {
                var encuesta = curso.Encuestas.FirstOrDefault();
                string estadoTexto = "Pendiente";
                string cardBorderClass = "";
                
                if (encuesta != null)
                {
                    if (encuesta.Estado == "Borrador")
                    {
                        estadoTexto = "Borrador Guardado";
                        cardBorderClass = "border-warning";
                    }
                    else if (encuesta.Estado == "Enviada")
                    {
                        estadoTexto = "Enviada Definitivamente";
                        cardBorderClass = "border-success-subtle";
                    }
                }
                
                // Color badges overrides for premium feel
                string customBadgeStyle = "";
                if (estadoTexto == "Pendiente")
                {
                    customBadgeStyle = "background-color: #FEF2F2 !important; color: #991B1B !important; border: 1.5px solid #FCA5A5 !important;";
                }
                else if (estadoTexto == "Borrador Guardado")
                {
                    customBadgeStyle = "background-color: #FFFBEB !important; color: #92400E !important; border: 1.5px solid #FDE68A !important;";
                }
                else
                {
                    customBadgeStyle = "background-color: #ECFDF5 !important; color: #065F46 !important; border: 1.5px solid #A7F3D0 !important;";
                }

                <div class="col-md-6 col-lg-6">
                    <div class="info-card h-100 d-flex flex-column justify-content-between @cardBorderClass">
                        <div>
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                <span class="text-muted small fw-bold" style="letter-spacing: 0.05em;">ASIGNATURA</span>
                                <span class="info-badge" style="@customBadgeStyle">
                                    @estadoTexto
                                </span>
                            </div>
                            
                            <h3 class="h4 fw-bold mb-3" style="color: var(--usmp-dark-slate); line-height: 1.3;">
                                @curso.Nombre
                            </h3>
                            
                            @if (encuesta != null)
                            {
                                <div class="mt-2 text-muted small">
                                    <div class="d-flex justify-content-between py-1 border-bottom border-light">
                                        <span>Porcentaje registrado:</span>
                                        <strong class="text-dark">@encuesta.PorcentajeCumplimiento%</strong>
                                    </div>
                                    <div class="d-flex justify-content-between py-1">
                                        <span>Último cambio:</span>
                                        <strong class="text-dark">@encuesta.FechaUltimaModificacion.ToString("dd/MM/yyyy HH:mm")</strong>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="mt-2 text-muted small">
                                    <p class="mb-0 text-italic">Aún no has registrado ningún avance para este sílabo académico.</p>
                                </div>
                            }
                        </div>
                        
                        <div class="mt-4 pt-3 border-top border-light">
                            @if (encuesta == null || encuesta.Estado == "Borrador")
                            {
                                <a asp-action="DocenteFormulario" asp-route-cursoId="@curso.Id" class="btn btn-usmp-primary w-100 d-flex align-items-center justify-content-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                        <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z"/>
                                        <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z"/>
                                    </svg>
                                    @(encuesta == null ? "Completar Encuesta" : "Continuar Editando")
                                </a>
                            }
                            else
                            {
                                <a asp-action="DocenteFormulario" asp-route-cursoId="@curso.Id" class="btn btn-usmp-outline w-100 d-flex align-items-center justify-content-center gap-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye-fill" viewBox="0 0 16 16">
                                        <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                                        <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z"/>
                                    </svg>
                                    Ver Respuestas Enviadas
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
